# ---- Sprout configuration ----
# Get a FREE Gemini API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=paste-your-free-gemini-key-here

# Use Google AI Studio (free tier), NOT Vertex AI. Keep this FALSE.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional: override the model (free-tier friendly: gemini-2.5-flash, gemini-2.5-flash-lite)
SPROUT_MODEL=gemini-2.5-flash

# Optional: free data.gov.in key for LIVE mandi prices (Agmarknet).
# Leave unset to use the built-in public sample key (rate-limited).
# Get your own free key at https://data.gov.in (higher limits).
# DATA_GOV_API_KEY=your-free-data-gov-in-key
